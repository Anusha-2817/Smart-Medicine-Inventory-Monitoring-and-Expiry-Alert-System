
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# If your local postgres has no password, use: postgresql://postgres@localhost:5432/medistock
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/medistock

# JWT secret key — use any long random string in production
JWT_SECRET=your_jwt_secret_here

# Backend port (default: 5000)
PORT=5000